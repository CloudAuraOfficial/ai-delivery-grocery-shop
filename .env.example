# Application Insights (production)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx

# Application
ASPNETCORE_ENVIRONMENT=Production
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_CHAT_URL=/api/chat
