# PostgreSQL
POSTGRES_HOST=grocery-db
POSTGRES_PORT=5432
POSTGRES_DB=groceryshop
POSTGRES_USER=grocery
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=grocery-redis
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ISSUER=grocery-shop
JWT_AUDIENCE=grocery-shop
JWT_EXPIRY_MINUTES=60

# CORS
CORS_ORIGINS=https://aideliverygroceryshop.cloudaura.cloud

# AI Service
AI_SERVICE_URL=http://grocery-ai:8000
EMBEDDING_PROVIDER=ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://172.17.0.1:11434
QDRANT_URL=http://172.17.0.1:6333

# Azure OpenAI (production)
# EMBEDDING_PROVIDER=azure_openai
# LLM_PROVIDER=azure_openai
